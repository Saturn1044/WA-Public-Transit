# Server port
PORT=3001

# OneBusAway API (Puget Sound real-time transit)
# Get a free key at: https://onebusaway.org/api/
# The TEST key works for development with limited requests
OBA_API_KEY=TEST
OBA_BASE_URL=https://api.pugetsound.onebusaway.org

# Washington State Ferries API (no key required)
WSF_API_URL=https://www.wsdot.wa.gov/ferries/api/schedule/rest
